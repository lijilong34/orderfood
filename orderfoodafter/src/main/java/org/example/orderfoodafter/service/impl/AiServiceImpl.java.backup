        ChatCompletionCreateParams request;
        if (tools != null && !tools.isEmpty()) {
            request = ChatCompletionCreateParams.builder()
                    .model("glm-4.6v-flash")
                    .messages(messages)
                    .tools(tools)
                    .build();
        } else {
            request = ChatCompletionCreateParams.builder()
                    .model("glm-4.6v-flash")
                    .messages(messages)
                    .build();
        }

        // 璋冪敤鏅鸿氨AI锛岃繑鍥炲畬鏁村搷搴?        ChatCompletionResponse response = zhipuClient.chat().createChatCompletion(request);

        if (response.isSuccess()) {
            return response;
        } else {
                /**
     * RuntimeException
     * 
     * @author 鏉庡悏闅?     */
            throw new RuntimeException("鏅鸿氨AI璋冪敤澶辫触: " + response.getMsg());
        }
    }
/**
 * getImageDescription鏂规硶
 *
 * @author 鏉庡悏闅? */

    @Override
    public String getImageDescription(String imgname) throws Exception {
        if (imgname == null || imgname.trim().isEmpty()) {
            return "鐢ㄦ埛鏈笂浼犲浘鐗?;
        }

        String filepath = defaulteProperties.getUploadfilepath() + imgname;
            /**
     * readAllBytes
     * 
     * @author 鏉庡悏闅?     */
        byte[] bytes = Files.readAllBytes(new File(filepath).toPath());
        String base64 = Base64.getEncoder().encodeToString(bytes);

        ChatCompletionCreateParams request = ChatCompletionCreateParams.builder()
                .model("glm-4.6v-flash")
                .messages(List.of(
                        ChatMessage.builder()
                                .role(ChatMessageRole.USER.value())
                                .content(List.of(
                                        MessageContent.builder()
                                                .type("text")
                                                .text("绠€瑕佹弿杩颁笅杩欏紶鍥剧墖,鍙緭鍑虹畝瑕佹弿杩板悗鐨勫氨琛屼簡")
                                                .build(),
                                        MessageContent.builder()
                                                .type("image_url")
                                                .imageUrl(ImageUrl.builder()
                                                        .url(base64)
                                                        .build())
                                                .build()))
                                .build()))
                .build();

        ChatCompletionResponse response = imageClient.chat().createChatCompletion(request);
        Object reply = null;
        if (response.isSuccess()) {
            ChatMessage message = response.getData().getChoices().get(0).getMessage();
            reply = message.getContent();
        } else {
            System.err.println("閿欒: " + response.getMsg());
        }

        if (reply == null) {
            return "鍥剧墖鎻忚堪鑾峰彇澶辫触";
        }

        return reply.toString();
    }

    @Override
        /**
     * executeToolLoop
     * 
     * @author 鏉庡悏闅?     */
    public String executeToolLoop(List<dev.langchain4j.data.message.ChatMessage> messages,
                                       List<ToolSpecification> tools,
                                       org.example.orderfoodafter.service.McpService mcpService,
                                       int maxRetries) {
                // 淇濆瓨宸ュ叿鎵ц杩囩▼鐨勫垪琛紝鐢ㄤ簬杩斿洖缁欏墠绔樉绀拒绝执行：                List<String> toolExecutionProcess = new ArrayList<>();
    
                try {
                    int iteration = 0;
                    // 娣诲姞鏈€澶ц凯浠ｆ鏁伴檺鍒讹紝闃叉鏃犻檺寰幆
                    final int MAX_ITERATIONS = 15; // 鏈€澶氭墽琛?5杞惊鐜?                    int consecutiveFailures = 0; // 杩炵画澶辫触娆℃暟
                    // 閲嶅鎿嶄綔妫€娴?                    int duplicateOperationCount = 0;
                    String lastToolName = "";
                    String lastToolArgs = "";        // 娣诲姞涓枃绯荤粺鎻愮ず锛岀‘淇滱I鑳藉鐞嗚В涓枃鎸囦护骞舵纭墽琛屽伐鍏疯皟鐢?        List<dev.langchain4j.data.message.ChatMessage> enhancedMessages = new ArrayList<>();
        enhancedenhancedMessages.add(new dev.langchain4j.data.message.SystemMessage(
            "銆愰噸瑕併€戜綘鏄尽鑶虫埧鐐归绯荤粺鐨勬櫤鑳藉姪鎵嬶紝浣跨敤MCP宸ュ叿鎺у埗娴忚鍣ㄥ畬鎴愪换鍔°€俓n\n" +
            "銆愬叧閿鍒欍€慭n" +
            "1. 浠诲姟瀹屾垚鍚庯紝绔嬪嵆鍋滄璋冪敤宸ュ叿锛岀敤涓枃缁欑敤鎴锋€荤粨鎵ц缁撴灉\n" +
            "2. 涓嶈閲嶅鎵ц鐩稿悓鐨勬搷浣滐紙濡傞噸澶嶇偣鍑诲悓涓€鍏冪礌锛塡n" +
            "3. 姣忔宸ュ叿璋冪敤鍚庯紝鏍规嵁缁撴灉鍐冲畾涓嬩竴姝ワ紝鑰屼笉鏄満姊板湴鎵ц鍥哄畾娴佺▼\n" +
            "4. 濡傛灉閬囧埌椤甸潰鍙樺寲鎴栨搷浣滄棤鏁堬紝灏濊瘯鍏朵粬鏂规硶\n" +
            "5. 鏈€澶氭墽琛?0-15娆″伐鍏疯皟鐢紝涔嬪悗蹇呴』缁欏嚭鏈€缁堢粨鏋淺n\n" +
            "銆愪綍鏃跺仠姝㈠伐鍏疯皟鐢ㄣ€慭n" +
            "- 鐢ㄦ埛璇锋眰宸叉弧瓒筹紙濡傚晢鍝佸凡娣诲姞鍒拌喘鐗╄溅銆佽鍗曞凡鍒涘缓绛夛級\n" +
            "- 椤甸潰宸茬粡鍒拌揪鐩爣鐘舵€侊紙濡傝喘鐗╄溅椤甸潰銆佽鍗曠‘璁ら〉闈級\n" +
            "- 杩炵画3娆℃墽琛岀浉鍚屾搷浣滀笖椤甸潰鏃犲彉鍖朶n" +
            "- 鎿嶄綔澶辫触2娆′互涓奬n" +
            "- 宸叉墽琛?0娆′互涓婂伐鍏疯皟鐢╘n\n" +
            "銆愬彲鐢ㄥ伐鍏枫€慭n" +
            "- chrome_read_page锛氳鍙栭〉闈㈠唴瀹癸紝浜嗚В褰撳墠鐘舵€乗n" +
            "- chrome_click_element锛氱偣鍑婚〉闈㈠厓绱燶n" +
            "- chrome_computer锛氭洿鐏垫椿鐨勯紶鏍囬敭鐩樻搷浣淺n" +
            "- chrome_navigate锛氬鑸埌鎸囧畾URL\n\n" +
            "銆愯浣忋€戝畬鎴愪换鍔″悗鍋滄宸ュ叿璋冪敤锛岀粰鍑烘渶缁堢粨鏋滐紒"
        ));
        enhancedMessages.addAll(messages);
        
        while (true) {
            iteration++;
            System.out.println("=== 宸ュ叿璋冪敤寰幆 " + iteration + " ===");
            
            // 妫€鏌ユ槸鍚﹁揪鍒版渶澶ц凯浠ｆ鏁?            if (iteration > MAX_ITERATIONS) {
                System.out.println("宸茶揪鍒版渶澶ц凯浠ｆ鏁?" + MAX_ITERATIONS + ")锛屽己鍒跺仠姝㈠惊鐜?);
                
                // 璁〢I鍩轰簬褰撳墠鐘舵€佺粰鍑虹粨鏋?                try {
                    ChatRequest finalRequest = ChatRequest.builder()
                            .messages(enhancedMessages)
                            .build();
                    
                    var finalResponse = chatLanguageModel.chat(finalRequest);
                    AiMessage finalAiMessage = finalResponse.aiMessage();
                    
                    // 鍚堝苟宸ュ叿鎵ц杩囩▼鍜孉I鏈€缁堝洖澶拒绝执行：                    StringBuilder finalResult = new StringBuilder();
                    if (!toolExecutionProcess.isEmpty()) {
                        finalResult.append("【工具执行过程】\n");
                        for (String process : toolExecutionProcess) {
                            finalResult.append(process).append("\n");
                        }
                        finalResult.append("\n");
                    }
                    finalResult.append("銆愬凡杈惧埌鏈€澶ц凯浠ｆ鏁帮紝AI鍥炲銆慭n").append(finalAiMessage.text());
                    
                    return finalResult.toString();
                } catch (Exception ex) {
                    System.err.println("获取AI最终结果失败? " + ex.getMessage());
                    return "宸ュ叿璋冪敤娆℃暟杩囧锛屽凡鍋滄鎿嶄綔銆?;
                }
            }
            
            // 璋冪敤AI锛堢洿鎺ヤ娇鐢╡nhancedMessages锛孡angChain4j浼氳嚜鍔ㄥ鐞員oolExecutionResultMessage锛?            ChatRequest request = ChatRequest.builder()
                    .messages(enhancedMessages)
                    .toolSpecifications(tools)
                    .build();
            
            AiMessage aiMessage = null;
            try {
                System.out.println("=== AI璋冪敤 ===");
                System.out.println("宸ュ叿鏁伴噺: " + (tools != null ? tools.size() : 0));
                if (tools != null && !tools.isEmpty()) {
                    System.out.println("宸ュ叿鍒楄〃:");
                    for (ToolSpecification tool : tools) {
                        System.out.println("  - 宸ュ叿鍚嶇О: " + tool.name());
                        System.out.println("    宸ュ叿鎻忚堪: " + tool.description());
                        System.out.println("    鍙傛暟瀹氫箟: " + (tool.parameters() != null ? tool.parameters().toString() : "鏃?));
                    }
                } else {
                    System.out.println("璀﹀憡: 宸ュ叿鍒楄〃涓虹┖锛?);
                }
                System.out.println("娑堟伅鏁伴噺: " + enhancedMessages.size());
                System.out.println("ChatRequest宸ュ叿瑙勮寖鏁伴噺: " + (request.toolSpecifications() != null ? request.toolSpecifications().size() : 0));
                System.out.println("=== 璇︾粏娑堟伅鍒楄〃 ===");
                for (int i = 0; i < enhancedMessages.size(); i++) {
                    dev.langchain4j.data.message.ChatMessage msg = enhancedMessages.get(i);
                    System.out.println("娑堟伅 #" + i + ": " + msg.getClass().getSimpleName());
                    if (msg instanceof dev.langchain4j.data.message.ToolExecutionResultMessage) {
                        dev.langchain4j.data.message.ToolExecutionResultMessage toolMsg = 
                            (dev.langchain4j.data.message.ToolExecutionResultMessage) msg;
                        System.out.println("  宸ュ叿鍚嶇О: " + toolMsg.toolName());
