                return finalResult.toString();
            }
            // 娌℃湁宸ュ叿鎵ц杩囩▼锛岃繑鍥炵畝鍗曠殑鎴愬姛娑堟伅
            return "鎿嶄綔瀹屾垚";
        }
    }

    @Override
        /**
     * executeToolLoopWithSSE
     *
     * @author 鏉庡悏闅?     */
    public void executeToolLoopWithSSE(SseEmitter emitter, String message,
                                        List<ToolSpecification> tools,
                                        org.example.orderfoodafter.service.McpService mcpService,
                                        int maxRetries) throws Exception {
        // 瀹夊叏鐨凷SE鍙戦€佹柟娉?        java.util.function.BiConsumer<String, String> safeSend = (eventName, data) -> {
            try {
                emitter.send(SseEmitter.event().name(eventName).data(data));
            } catch (Exception e) {
                String errorMsg = e.getMessage();
                if (errorMsg != null && (errorMsg.contains("宸插缓绔嬬殑杩炴帴") ||
                    errorMsg.contains("Broken pipe") ||
                    errorMsg.contains("Connection reset") ||
                    errorMsg.contains("ResponseBodyEmitter has already completed") ||
                    errorMsg.contains("already completed"))) {
                    System.out.println("SSE鍙戦€佸け璐ワ紝杩炴帴宸叉柇寮€鎴杄mitter宸插畬鎴愶紝浜嬩欢: " + eventName);
                    // 涓嶆姏鍑哄紓甯革紝缁х画鎵ц
                } else {
                    System.err.println("SSE鍙戦€佸け璐ワ紝浜嬩欢: " + eventName + ", 閿欒: " + e.getMessage());
                }
            }
        };

        try {
            // 鏋勫缓瀵硅瘽娑堟伅
            List<dev.langchain4j.data.message.ChatMessage> messages = new ArrayList<>();
            enhancedMessages.add(new dev.langchain4j.data.message.SystemMessage(
                "銆愰噸瑕併€戜綘鏄尽鑶虫埧鐐归绯荤粺鐨勬櫤鑳藉姪鎵嬶紝浣跨敤MCP宸ュ叿鎺у埗娴忚鍣ㄥ畬鎴愪换鍔°€俓n\n" +
                "銆愬叧閿鍒欍€慭n" +
                "1. 浠诲姟瀹屾垚鍚庯紝绔嬪嵆鍋滄璋冪敤宸ュ叿锛岀敤涓枃缁欑敤鎴锋€荤粨鎵ц缁撴灉\n" +
                "2. 涓嶈閲嶅鎵ц鐩稿悓鐨勬搷浣滐紙濡傞噸澶嶇偣鍑诲悓涓€鍏冪礌锛塡n" +
                "3. 姣忔宸ュ叿璋冪敤鍚庯紝鏍规嵁缁撴灉鍐冲畾涓嬩竴姝ワ紝鑰屼笉鏄満姊板湴鎵ц鍥哄畾娴佺▼\n" +
                "4. 濡傛灉閬囧埌椤甸潰鍙樺寲鎴栨搷浣滄棤鏁堬紝灏濊瘯鍏朵粬鏂规硶\n" +
                "5. 鏈€澶氭墽琛?0-15娆″伐鍏疯皟鐢紝涔嬪悗蹇呴』缁欏嚭鏈€缁堢粨鏋淺n\n" +
                "銆愪綍鏃跺仠姝㈠伐鍏疯皟鐢ㄣ€慭n" +
                "- 鐢ㄦ埛璇锋眰宸叉弧瓒筹紙濡傚晢鍝佸凡娣诲姞鍒拌喘鐗╄溅銆佽鍗曞凡鍒涘缓绛夛級\n" +
                "- 椤甸潰宸茬粡鍒拌揪鐩爣鐘舵€侊紙濡傝喘鐗╄溅椤甸潰銆佽鍗曠‘璁ら〉闈級\n" +
                "- 杩炵画3娆℃墽琛岀浉鍚屾搷浣滀笖椤甸潰鏃犲彉鍖朶n" +
                "- 鎿嶄綔澶辫触2娆′互涓奬n" +
                "- 宸叉墽琛?0娆′互涓婂伐鍏疯皟鐢╘n\n" +
                "銆愬彲鐢ㄥ伐鍏枫€慭n" +
                "- chrome_read_page锛氳鍙栭〉闈㈠唴瀹癸紝浜嗚В褰撳墠鐘舵€乗n" +
                "- chrome_click_element锛氱偣鍑婚〉闈㈠厓绱燶n" +
                "- chrome_computer锛氭洿鐏垫椿鐨勯紶鏍囬敭鐩樻搷浣淺n" +
                "- chrome_navigate锛氬鑸埌鎸囧畾URL\n\n" +
                "銆愯浣忋€戝畬鎴愪换鍔″悗鍋滄宸ュ叿璋冪敤锛岀粰鍑烘渶缁堢粨鏋滐紒"
            ));
            enhancedMessages.add(dev.langchain4j.data.message.UserMessage.from(message));

            int iteration = 0;
            boolean allToolsSucceeded = true;
            int consecutiveFailures = 0; // 杩炵画澶辫触娆℃暟
            final int MAX_ITERATIONS = 15; // 鏈€澶氭墽琛?5杞惊鐜?            int duplicateOperationCount = 0; // 閲嶅鎿嶄綔璁℃暟
            String lastToolName = "";
            String lastToolArgs = "";

            while (true) {
                iteration++;
                System.out.println("=== 宸ュ叿璋冪敤寰幆 " + iteration + " ===");

                // 鎺ㄩ€佸惊鐜紑濮嬩簨浠?                safeSend.accept("loop_start", "绗?" + iteration + " 杞惊鐜?);

                // 妫€鏌ユ槸鍚﹁揪鍒拌繛缁け璐ユ鏁颁笂闄?                if (consecutiveFailures >= 5) {
                    System.out.println("宸ュ叿杩炵画澶辫触" + consecutiveFailures + "娆★紝鍋滄杩唬");
                    safeSend.accept("error", "宸ュ叿杩炵画澶辫触" + consecutiveFailures + "娆★紝鍋滄杩唬");
                    emitter.complete();
                    return;
                }

                // 妫€鏌ユ槸鍚﹁揪鍒版渶澶ц凯浠ｆ鏁?                if (iteration > MAX_ITERATIONS) {
