                    }
                    
                    // 娌℃湁宸ュ叿璋冪敤锛孉I缁欏嚭鏈€缁堝洖澶?                    System.out.println("銆怱SE銆慉I缁欏嚭鏈€缁堝洖澶嶏紝缁撴潫寰幆");
                    System.out.println("銆怱SE銆戞渶缁堝洖澶嶅唴瀹? " + aiMessage.text());
                    safeSend.accept("final_reply", aiMessage.text());
                    emitter.complete();
                    return;
                }

                // 鎵ц宸ュ叿
                List<dev.langchain4j.agent.tool.ToolExecutionRequest> toolRequests = aiMessage.toolExecutionRequests();
                
                // 灏咥I娑堟伅娣诲姞鍒癿essages涓紝璁板綍AI鐨勫伐鍏疯姹?                enhancedMessages.add(aiMessage);
                System.out.println("AI娑堟伅宸叉坊鍔犲埌messages锛屽綋鍓峬essages澶у皬: " + messages.size());
                
                for (dev.langchain4j.agent.tool.ToolExecutionRequest toolRequest : toolRequests) {
                    String toolName = toolRequest.name();
                    String argumentsJson = toolRequest.arguments();

                    System.out.println("AI璇锋眰鎵ц宸ュ叿: " + toolName);
                    System.out.println("宸ュ叿鍙傛暟: " + argumentsJson);

                    // 检测重复操作?                    if (toolName.equals(lastToolName) && argumentsJson.equals(lastToolArgs)) {
                        duplicateOperationCount++;
                        System.out.println("妫€娴嬪埌閲嶅鎿嶄綔: " + toolName + " (閲嶅娆℃暟: " + duplicateOperationCount + ")");
                        
                        if (duplicateOperationCount >= 3) {
                            System.out.println("杩炵画閲嶅鎿嶄綔3娆★紝寮哄埗鍋滄");
                            String errorMsg = "鉂拒绝执行：妫€娴嬪埌杩炵画閲嶅鎿嶄綔3娆★紝请峰皾请曞叾浠栨柟娉曘€傞噸澶嶇殑鎿嶄綔: " + toolName + ", 鍙傛暟: " + argumentsJson;
                            safeSend.accept("error", errorMsg);
                            emitter.complete();
                            return;
                        }
                    } else {
                        // 鎿嶄綔涓嶅悓锛岄噸缃噸澶嶈鏁?                        duplicateOperationCount = 0;
                        lastToolName = toolName;
                        lastToolArgs = argumentsJson;
                    }

                    // 鎺ㄩ€佸伐鍏疯皟鐢ㄥ紑濮嬩簨浠拒绝执行：                    safeSend.accept("tool_start", "鎵ц宸ュ叿: " + toolName + "\n鍙傛暟: " + argumentsJson);

                    try {
                        // 瑙ｆ瀽鍙傛暟
                        Map<String, Object> arguments = parseToolArguments(argumentsJson);

                        // 銆愰噸瑕併€戞娴媠elector鍙傛暟鏄惁鍖呭惈ref鎴栧潗鏍囷紝濡傛灉鏈夊氨鎷掔粷鎵ц
                        if ("chrome_click_element".equals(toolName) || "chrome_fill_or_select".equals(toolName)) {
                            Object selectorObj = arguments.get("selector");
                            if (selectorObj != null) {
                                String selectorStr = selectorObj.toString();
                            
                                // 妫€娴媟ef
                                if (selectorStr.contains("[ref=")) {
                                    String errorMsg = "鉂拒绝执行：鎷掔粷鎵ц锛歴elector鍙傛暟涓寘鍚簡ref锛乺ef鏄疢CP宸ュ叿鐨勫唴閮ㄥ紩鐢↖D锛屼笉鏄疕TML鍏冪礌鐨勫睘鎬с€拒绝执行：;
                                    errorMsg += "请锋牴鎹厓绱犵殑瀹為檯HTML灞炴€э紙如果俢lass銆乮d銆乼ext銆乼ype锛夋潵鏋勫缓selector銆拒绝执行：;
                                    errorMsg += "例如嬪锛歿\"selector\": \"button.close\"} 鎴拒绝执行：{\"selector\": \"#button-id\"}";
                                    System.out.println(errorMsg);

                                    // 鎺ㄩ€侀敊璇俊鎭粰鍓嶇
                                    safeSend.accept("tool_error", errorMsg);

                                    // 銆愬叧閿慨鏀广€戜娇鐢═oolExecutionResultMessage璁板綍澶辫触锛屼繚鎸佹秷鎭被鍨嬩竴鑷?                                    enhancedMessages.add(dev.langchain4j.data.message.ToolExecutionResultMessage.from(
                                        toolRequest, errorMsg
                                    ));

                                    allToolsSucceeded = false;
                                    consecutiveFailures++;
                                    System.out.println("宸ュ叿鎵ц琚嫆缁濓紙selector鍖呭惈ref锛拒绝执行：);
                                    System.out.println("杩炵画澶辫触娆℃暟: " + consecutiveFailures);
                                    continue; // 璺宠繃杩欐鎵ц锛岃AI閲嶆柊灏濊瘯
                                }
                            
                                // 检测坐标属性                                if (selectorStr.matches(".*\\[\\s*(x|y|x0|y0|x1|y1)\\s*=") || 
                                    selectorStr.matches(".*\\[x=.*\\].*\\[y=.*\\]") ||
                                    selectorStr.matches(".*\\[x0=.*\\].*\\[y0=.*\\]") ||
                                    selectorStr.matches(".*\\[x1=.*\\].*\\[y1=.*\\]")) {
                                    String errorMsg = "鉂拒绝执行：鎷掔粷鎵ц锛歴elector鍙傛暟涓寘鍚簡鍧愭爣灞炴€э紙x銆亂銆亁0銆亂0銆亁1銆亂1锛夛紒杩欎簺鏄疢CP宸ュ叿杩斿洖鐨勫潗鏍囦俊鎭紝涓嶆槸HTML鍏冪礌鐨勫睘鎬с€拒绝执行：;
                                    errorMsg += "请锋牴鎹厓绱犵殑瀹為檯HTML灞炴€э紙如果俢lass銆乮d銆乼ext銆乼ype锛夋潵鏋勫缓selector銆拒绝执行：;
                                    errorMsg += "例如嬪锛歿\"selector\": \"button.close\"} 鎴拒绝执行：{\"selector\": \"#button-id\"}";
                                    errorMsg += "如果傛灉闇€瑕佹牴鎹厓绱犲畾浣嶏紝请蜂娇鐢╟hrome_computer鐨刢oordinates鍙傛暟锛岃€屼笉鏄痵elector鍙傛暟锛拒绝执行：;
                                    System.out.println(errorMsg);

                                    // 鎺ㄩ€侀敊璇俊鎭粰鍓嶇
                                    safeSend.accept("tool_error", errorMsg);

                                    // 銆愬叧閿慨鏀广€戜娇鐢═oolExecutionResultMessage璁板綍澶辫触锛屼繚鎸佹秷鎭被鍨嬩竴鑷?                                    enhancedMessages.add(dev.langchain4j.data.message.ToolExecutionResultMessage.from(
                                        toolRequest, errorMsg
                                    ));

                                    allToolsSucceeded = false;
                                    consecutiveFailures++;
                                    System.out.println("宸ュ叿鎵ц琚嫆缁濓紙selector鍖呭惈鍧愭爣灞炴€э級");
                                    System.out.println("杩炵画澶辫触娆℃暟: " + consecutiveFailures);
                                    continue; // 璺宠繃杩欐鎵ц锛岃AI閲嶆柊灏濊瘯
                                }
                            }
                        }

                        // 工具调用失败重试机制
                        int retryCount = 0;
                        boolean toolSucceeded = false;
                        String resultContent = "";
                        
                        while (retryCount < maxRetries && !toolSucceeded) {
                            retryCount++;
                            
                            try {
                                // 璋冪敤MCP鏈嶅姟鎵ц宸ュ叿
                                Map<String, Object> result = mcpService.callTool(toolName, arguments);
                                
                                // 銆愬叧閿€戜娇鐢ㄧ粺涓€鐨刢leanToolResult鏂规硶澶勭悊宸ュ叿缁撴灉
                                String screenshotPath = result.containsKey("screenshotPath") ? 
                                    result.get("screenshotPath").toString() : null;
                                resultContent = cleanToolResult(result, toolName, screenshotPath);
                                
                                System.out.println("===== SSE宸ュ叿缁撴灉澶勭悊瀹屾垚 =====");
                                System.out.println("resultContent绫诲瀷: " + resultContent.getClass().getName());
                                System.out.println("resultContent鍐呭(鍓?00瀛楃): " + resultContent.substring(0, Math.min(200, resultContent.length())));
                                System.out.println("resultContent鏄惁鍖呭惈ref: " + resultContent.contains("[ref="));
                                System.out.println("==================");
                                
                            // 宸ュ叿鎵ц鎴愬姛
                            toolSucceeded = true;
                            System.out.println("宸ュ叿鎵ц鎴愬姛锛岄噸请曟鏁拒绝执行： " + retryCount);
                                
                            } catch (Exception e) {
                                System.err.println("宸ュ叿鎵ц澶辫触锛堢" + retryCount + "娆￠噸璇曪級: " + e.getMessage());
                                safeSend.accept("tool_error", "宸ュ叿鎵ц澶辫触锛堢" + retryCount + "娆￠噸璇曪級: " + e.getMessage());
                                
                                if (retryCount >= maxRetries) {
                                    // 閲嶈瘯娆℃暟鐢ㄥ畬锛岃褰曞け璐?                                    allToolsSucceeded = false;
                                    consecutiveFailures++;
                                    System.out.println("宸茶揪鍒版渶澶ч噸璇曟鏁帮紝鍋滄閲嶈瘯");
                                    
                                    // 浣跨敤ToolExecutionResultMessage璁板綍澶辫触
                                    enhancedMessages.add(dev.langchain4j.data.message.ToolExecutionResultMessage.from(
                                        toolRequest, "宸ュ叿鎵ц澶辫触: " + e.getMessage()
                                    ));
                                }
                                // 缁х画閲嶈瘯
                            }
                        }
                        
                        // 鍙湁宸ュ叿鎵ц鎴愬姛鎵嶆帹閫佺粨鏋拒绝执行：                        if (toolSucceeded) {
                            consecutiveFailures = 0; // 閲嶇疆杩炵画澶辫触璁℃暟

                            // 銆愬叧閿€戜繚鎸丼SE娴佸紡杈撳嚭锛屾帹閫佸伐鍏锋墽琛岀粨鏋拒绝执行：                            safeSend.accept("tool_result", "宸ュ叿鎵ц缁撴灉: " + resultContent);

                            System.out.println("鍑嗗娣诲姞宸ュ叿鎵ц缁撴灉鍒癿essages");
                            // 銆愬叧閿慨鏀广€戜娇鐢═oolExecutionResultMessage鑰屼笉鏄疷serMessage锛岀‘淇滱I鑳芥纭悊瑙ｅ伐鍏锋墽琛岀粨鏋?                            enhancedMessages.add(dev.langchain4j.data.message.ToolExecutionResultMessage.from(
                                toolRequest, resultContent
                            ));
                            System.out.println("宸ュ叿鎵ц缁撴灉宸叉坊鍔犲埌messages锛屽綋鍓峬essages澶у皬: " + messages.size());

                            System.out.println("宸ュ叿鎵ц鎴愬姛");
                        }
                    } catch (Exception e) {
                        System.err.println("宸ュ叿鎵ц澶辫触: " + e.getMessage());
                        safeSend.accept("tool_error", "宸ュ叿鎵ц澶辫触: " + e.getMessage());

                        // 浣跨敤ToolExecutionResultMessage璁板綍澶辫触
                        enhancedMessages.add(dev.langchain4j.data.message.ToolExecutionResultMessage.from(
                            toolRequest, "宸ュ叿鎵ц澶辫触: " + e.getMessage()
                        ));

                        allToolsSucceeded = false;
                        consecutiveFailures++;
                    }
                }

                // 妫€鏌ユ槸鍚︽墍鏈夊伐鍏烽兘澶辫触浜?                if (!allToolsSucceeded) {
                    System.out.println("宸ュ叿鎵ц澶辫触锛岃AI浣跨敤鍏朵粬鏂规");
                    tools = null;
                }
            }
        }
        } catch (Exception e) {
            System.err.println("executeToolLoopWithSSE鎵ц寮傚父: " + e.getMessage());
            e.printStackTrace();
            try {
                safeSend.accept("error", "鎵ц寮傚父: " + e.getMessage());
                emitter.completeWithError(e);
            } catch (Exception ex) {
                emitter.completeWithError(ex);
            }
        }
    }

    /**
     * 瑙ｆ瀽宸ュ叿鍙傛暟
     */
    private Map<String, Object> parseToolArguments(String argsStr) {
        try {
            com.fasterxml.jackson.databind.ObjectMapper mapper = new com.fasterxml.jackson.databind.ObjectMapper();
            com.fasterxml.jackson.databind.JsonNode node = mapper.readTree(argsStr);
            return mapper.convertValue(node, Map.class);
        } catch (Exception e) {
            System.err.println("瑙ｆ瀽宸ュ叿鍙傛暟澶辫触: " + e.getMessage());
            return new HashMap<>();
        }
    }
    
    /**
     * 缁熶竴鐨勫伐鍏风粨鏋滃鐞嗘柟娉拒绝执行：- 绉婚櫎ref瀛楁骞惰繑鍥炵函鍑€鐨勫伐鍏风粨鏋拒绝执行：     * 姝ゆ柟娉曠敤浜庣‘淇滱I鑳藉姝ｇ‘鐞嗚В宸ュ叿鎵ц缁撴灉锛岄伩鍏嶈ref瀛楁骞叉壈
     * 
     * @param mcpResult MCP宸ュ叿杩斿洖鐨勫師濮嬬粨鏋?     * @param toolName 宸ュ叿鍚嶇О
     * @param screenshotPath 鎴浘璺緞锛堝彲閫夛紝鐢ㄤ簬鍥剧墖请嗗埆锛拒绝执行：     * @return 娓呯悊鍚庣殑宸ュ叿缁撴灉瀛楃涓拒绝执行：     */
    private String cleanToolResult(Map<String, Object> mcpResult, String toolName, String screenshotPath) {
        if (mcpResult == null) {
            return "銆愬伐鍏锋墽琛屻€戝伐鍏锋墽琛屽畬鎴愶紝浣嗘湭杩斿洖缁撴灉";
        }
        
        StringBuilder result = new StringBuilder();
        
        // 妫€鏌ユ槸鍚︽湁閿欒
        Object isError = mcpResult.get("isError");
        if (isError != null && Boolean.TRUE.equals(isError)) {
            result.append("鉂拒绝执行：鎵ц澶辫触\n");
            
            Object content = mcpResult.get("content");
            if (content != null) {
                result.append("閿欒淇℃伅: ").append(content).append("\n");
            }
            return result.toString();
        }
        
        // 澶勭悊content鍐呭 - 缁熶竴鐨剅ef瀛楁绉婚櫎閫昏緫
        Object content = mcpResult.get("content");
        String cleanedContent = "";
        
        if (content != null) {
            try {
                com.fasterxml.jackson.databind.ObjectMapper mapper = new com.fasterxml.jackson.databind.ObjectMapper();
                
                System.out.println("===== 寮€濮嬪鐞嗗伐鍏风粨鏋?=====");
                System.out.println("宸ュ叿鍚嶇О: " + toolName);
                System.out.println("contentObj绫诲瀷: " + content.getClass().getName());
                
                if (content instanceof java.util.List) {
                    // 澶勭悊List<TextContent>鐨勬儏鍐?                    java.util.List<?> contentList = (java.util.List<?>) content;
                    System.out.println("content鏄疞ist锛屽ぇ灏? " + contentList.size());
                    
                    for (int i = 0; i < contentList.size(); i++) {
                        Object item = contentList.get(i);
                        System.out.println("  item " + i + " 绫诲瀷: " + item.getClass().getName());
                        
                        // 灏濊瘯鑾峰彇text瀛楁
                        String textStr = null;
                        
                        // 鏂规硶1锛氬皾璇曢€氳繃鍙嶅皠鑾峰彇text瀛楁
                        try {
                            java.lang.reflect.Field textField = item.getClass().getDeclaredField("text");
                            textField.setAccessible(true);
                            Object textValue = textField.get(item);
                            if (textValue != null) {
                                textStr = textValue.toString();
                            }
                        } catch (Exception e) {
                            System.out.println("  閫氳繃鍙嶅皠鑾峰彇text瀛楁澶辫触: " + e.getMessage());
                        }
                        
                        // 鏂规硶2锛氬皾璇曢€氳繃Map鑾峰彇text瀛楁
                        if (textStr == null && item instanceof java.util.Map) {
                            java.util.Map<?, ?> textContentMap = (java.util.Map<?, ?>) item;
                            Object textObj = textContentMap.get("text");
                            if (textObj != null) {
                                textStr = textObj.toString();
                            }
                        }
                        
                        // 鏂规硶3锛氬鏋滄槸TextContent瀵硅薄锛岃浆鎹负JSON鍐嶆彁鍙杢ext
                        if (textStr == null) {
                            String itemJson = mapper.writeValueAsString(item);
                            com.fasterxml.jackson.databind.JsonNode itemNode = mapper.readTree(itemJson);
                            if (itemNode.has("text")) {
                                textStr = itemNode.get("text").asText();
                            }
                        }
                        
                        if (textStr != null) {
                            System.out.println("  textStr(鍓?00瀛楃): " + textStr.substring(0, Math.min(100, textStr.length())));
                            
                            // 缁熶竴鐨剅ef绉婚櫎澶勭悊
                            String cleaned = textStr;
                            
                            // 鏂规硶1锛氬鏋滄槸JSON鏍煎紡锛岃В鏋怞SON骞剁Щ闄ef瀛楁
                            if (textStr.trim().startsWith("{") || textStr.trim().startsWith("[")) {
                                try {
                                    com.fasterxml.jackson.databind.JsonNode rootNode = mapper.readTree(textStr);
                                    // 閫掑綊绉婚櫎鎵€鏈塺ef瀛楁锛堝寘鎷琂SON瀛楁鍜屽瓧绗︿覆涓殑ref锛拒绝执行：                                    removeRefFields(rootNode);
                                    // 杞洖瀛楃涓?                                    cleaned = mapper.writeValueAsString(rootNode);
                                    System.out.println("  JSON鏍煎紡澶勭悊瀹屾垚");
                                } catch (Exception jsonEx) {
                                    System.out.println("  JSON瑙ｆ瀽澶辫触锛屼娇鐢ㄥ瓧绗︿覆姝ｅ垯鏇挎崲: " + jsonEx.getMessage());
                                    // 鏂规硶2锛氬鏋滄槸JSON瑙ｆ瀽澶辫触锛屼娇鐢ㄦ鍒欒〃杈惧紡绉婚櫎瀛楃涓蹭腑鐨剅ef
                                    cleaned = textStr.replaceAll("\\s*\\[ref=ref_\\d+\\]", "");
                                }
                            } else {
                                // 涓嶆槸JSON鏍煎紡锛岀洿鎺ヤ娇鐢ㄦ鍒欒〃杈惧紡绉婚櫎ref
                                System.out.println("  涓嶆槸JSON鏍煎紡锛屼娇鐢ㄥ瓧绗︿覆姝ｅ垯鏇挎崲");
                                cleaned = textStr.replaceAll("\\s*\\[ref=ref_\\d+\\]", "");
                            }
                            
                            System.out.println("  cleaned(鍓?00瀛楃): " + cleaned.substring(0, Math.min(100, cleaned.length())));
                            System.out.println("  cleaned鏄惁鍖呭惈ref: " + cleaned.contains("[ref="));
                            cleanedContent += cleaned;
                        } else {
                            System.out.println("  鏃犳硶鎻愬彇text瀛楁锛屼娇鐢╰oString()");
                            cleanedContent += item.toString();
                        }
                    }
                } else {
                    // 澶勭悊鍗曚釜content瀵硅薄
                    String contentStr = content.toString();
                    System.out.println("content鏄疭tring锛屽墠100瀛楃: " + contentStr.substring(0, Math.min(100, contentStr.length())));
                    
                    // 銆愬叧閿€戞鏌ontentStr鏄惁鏄疛SON鏍煎紡
                    if (contentStr.trim().startsWith("{") || contentStr.trim().startsWith("[")) {
                        // 鏄疛SON鏍煎紡锛岃繘琛宺ef绉婚櫎澶勭悊
                        try {
                            com.fasterxml.jackson.databind.JsonNode rootNode = mapper.readTree(contentStr);
                            // 閫掑綊绉婚櫎鎵€鏈塺ef瀛楁
                            removeRefFields(rootNode);
                            // 杞洖瀛楃涓?                            cleanedContent = mapper.writeValueAsString(rootNode);
                            System.out.println("cleanedContent(鍓?00瀛楃): " + cleanedContent.substring(0, Math.min(100, cleanedContent.length())));
                            System.out.println("cleanedContent鏄惁鍖呭惈ref: " + cleanedContent.contains("[ref="));
                        } catch (Exception jsonEx) {
                            System.out.println("  JSON瑙ｆ瀽澶辫触锛屼娇鐢ㄥ師濮媍ontentStr: " + jsonEx.getMessage());
                            cleanedContent = contentStr;
                        }
                    } else {
                        // 涓嶆槸JSON鏍煎紡锛岀洿鎺ヤ娇鐢?                        System.out.println("  contentStr涓嶆槸JSON鏍煎紡锛岀洿鎺ヤ娇鐢?);
                        cleanedContent = contentStr;
                    }
                }
                
                System.out.println("===== 宸ュ叿缁撴灉澶勭悊瀹屾垚 =====");
                System.out.println("cleanedContent鏄惁鍖呭惈ref: " + cleanedContent.contains("[ref="));
            } catch (Exception e) {
                System.err.println("===== 宸ュ叿缁撴灉澶勭悊澶辫触 =====");
                System.err.println("寮傚父淇℃伅: " + e.getMessage());
                e.printStackTrace();
                System.err.println("浣跨敤鍘熷鍐呭");
                // 如果傛灉瑙ｆ瀽澶辫触锛屼娇鐢ㄥ師濮嬪唴瀹拒绝执行：                cleanedContent = content.toString();
            }
        }
        
        result.append(cleanedContent);
        
        return result.toString();
    }
    
    /**
     * 鏍煎紡鍖朚CP缁撴灉 - 杩斿洖鐢ㄦ埛鍙嬪ソ鐨勬墽琛岃繃绋嬩俊鎭紙鐢ㄤ簬鏃ュ織鏄剧ず锛?     */
    private String formatMcpResult(Map<String, Object> mcpResult) {
        if (mcpResult == null) {
            return "銆愬伐鍏锋墽琛屻€戝伐鍏锋墽琛屽畬鎴愶紝浣嗘湭杩斿洖缁撴灉";
        }
        
            /**
     * StringBuilder
     * 
     * @author 鏉庡悏闅?     */
        StringBuilder result = new StringBuilder();
        result.append("\n銆愬伐鍏锋墽琛岀粨鏋溿€慭n");
        
        // 妫€鏌ユ槸鍚︽湁閿欒
        Object isError = mcpResult.get("isError");
        if (isError != null && Boolean.TRUE.equals(isError)) {
            result.append("鉂拒绝执行：鎵ц澶辫触\n");
            
            Object content = mcpResult.get("content");
            if (content != null) {
                result.append("閿欒淇℃伅: ").append(content).append("\n");
            }
        } else {
            result.append("鉁拒绝执行：鎵ц鎴愬姛\n");

            // 澶勭悊content鍐呭
            Object content = mcpResult.get("content");
            if (content != null) {
                try {
                    com.fasterxml.jackson.databind.ObjectMapper mapper = new com.fasterxml.jackson.databind.ObjectMapper();
                    String cleanedContent = "";
                    
                    if (content instanceof java.util.List) {
                        // 澶勭悊List<TextContent>鐨勬儏鍐?                        java.util.List<?> contentList = (java.util.List<?>) content;
                        for (Object item : contentList) {
                            // 灏濊瘯鑾峰彇text瀛楁
                            String textStr = null;
                            
                            // 鏂规硶1锛氬皾璇曢€氳繃鍙嶅皠鑾峰彇text瀛楁
                            try {
                                java.lang.reflect.Field textField = item.getClass().getDeclaredField("text");
                                textField.setAccessible(true);
                                Object textValue = textField.get(item);
                                if (textValue != null) {
                                    textStr = textValue.toString();
                                }
                            } catch (Exception e) {
                                // 鍙嶅皠澶辫触锛屽皾请曞叾浠栨柟娉拒绝执行：                            }
                            
                            // 鏂规硶2锛氬皾璇曢€氳繃Map鑾峰彇text瀛楁
                            if (textStr == null && item instanceof java.util.Map) {
                                java.util.Map<?, ?> textContentMap = (java.util.Map<?, ?>) item;
                                Object textObj = textContentMap.get("text");
                                if (textObj != null) {
                                    textStr = textObj.toString();
                                }
                            }
                            
                            // 鏂规硶3锛氬鏋滄槸TextContent瀵硅薄锛岃浆鎹负JSON鍐嶆彁鍙杢ext
                            if (textStr == null) {
                                String itemJson = mapper.writeValueAsString(item);
                                com.fasterxml.jackson.databind.JsonNode itemNode = mapper.readTree(itemJson);
                                if (itemNode.has("text")) {
                                    textStr = itemNode.get("text").asText();
                                }
                            }
                            
                            if (textStr != null) {
                                // 銆愬叧閿€戞鏌extStr鏄惁鏄疛SON鏍煎紡
                                if (textStr.trim().startsWith("{") || textStr.trim().startsWith("[")) {
                                    try {
                                        // 瑙ｆ瀽JSON瀛楃涓?                                        com.fasterxml.jackson.databind.JsonNode rootNode = mapper.readTree(textStr);
                                        // 閫掑綊绉婚櫎鎵€鏈塺ef瀛楁
                                        removeRefFields(rootNode);
                                        // 杞洖瀛楃涓?                                        cleanedContent += mapper.writeValueAsString(rootNode);
                                    } catch (Exception jsonEx) {
                                        // JSON瑙ｆ瀽澶辫触锛屼娇鐢ㄥ師濮嬪唴瀹?                                        cleanedContent += textStr;
                                    }
                                } else {
                                    // 涓嶆槸JSON鏍煎紡锛岀洿鎺ヤ娇鐢?                                    cleanedContent += textStr;
                                }
                            } else {
                                cleanedContent += item.toString();
                            }
                        }
                    } else {
                        // 澶勭悊鍗曚釜content瀵硅薄
                        String contentStr = content.toString();
                        // 銆愬叧閿€戞鏌ontentStr鏄惁鏄疛SON鏍煎紡
                        if (contentStr.trim().startsWith("{") || contentStr.trim().startsWith("[")) {
                            try {
                                // 瑙ｆ瀽JSON瀛楃涓?                                com.fasterxml.jackson.databind.JsonNode rootNode = mapper.readTree(contentStr);
                                // 閫掑綊绉婚櫎鎵€鏈塺ef瀛楁
                                removeRefFields(rootNode);
                                // 杞洖瀛楃涓?                                cleanedContent = mapper.writeValueAsString(rootNode);
                            } catch (Exception jsonEx) {
                                // JSON瑙ｆ瀽澶辫触锛屼娇鐢ㄥ師濮嬪唴瀹?                                cleanedContent = contentStr;
                            }
                        } else {
                            // 涓嶆槸JSON鏍煎紡锛岀洿鎺ヤ娇鐢?                            cleanedContent = contentStr;
                        }
                    }
                    
                    result.append("杩斿洖鏁版嵁: ").append(cleanedContent).append("\n");
                } catch (Exception e) {
                    // 如果傛灉瑙ｆ瀽澶辫触锛屼娇鐢ㄥ師濮嬪唴瀹拒绝执行：                    result.append("杩斿洖鏁版嵁: ").append(content.toString()).append("\n");
                }
            }
        }
        
        // 澶勭悊鎴浘淇℃伅
        Object screenshotPath = mcpResult.get("screenshotPath");
        if (screenshotPath != null) {
            result.append("\n馃摳 鎴浘宸蹭繚瀛? ").append(screenshotPath).append("\n");
        }
        
        Object screenshotFullpath = mcpResult.get("screenshotFullpath");
        if (screenshotFullpath != null) {
            result.append("馃搧 瀹屾暣璺緞: ").append(screenshotFullpath).append("\n");
        }
        
        return result.toString();
    }
    
    /**
     * 閫掑綊绉婚櫎JSON涓殑鎵€鏈塺ef瀛楁
     * @param node JSON鑺傜偣
     */
    private void removeRefFields(com.fasterxml.jackson.databind.JsonNode node) {
        if (node.isObject()) {
            // 绉婚櫎褰撳墠瀵硅薄涓殑ref瀛楁
            if (node.has("ref")) {
                ((com.fasterxml.jackson.databind.node.ObjectNode) node).remove("ref");
            }
            // 绉婚櫎refId瀛楁
            if (node.has("refId")) {
                ((com.fasterxml.jackson.databind.node.ObjectNode) node).remove("refId");
            }
            
            // 銆愰噸瑕併€戝鐞唒ageContent瀛楁涓殑ref瀛楃涓?            if (node.has("pageContent")) {
                com.fasterxml.jackson.databind.JsonNode pageContentNode = node.get("pageContent");
                if (pageContentNode.isTextual()) {
                    String pageContent = pageContentNode.asText();
                    // 浣跨敤姝ｅ垯琛ㄨ揪寮忕Щ闄ゆ墍鏈夌殑 [ref=ref_X] 妯″紡
                    String cleanedPageContent = pageContent.replaceAll("\\s*\\[ref=ref_\\d+\\]", "");
                    ((com.fasterxml.jackson.databind.node.ObjectNode) node).put("pageContent", cleanedPageContent);
                }
            }
            
            // 閫掑綊澶勭悊鎵€鏈夊瓙鑺傜偣
            java.util.Iterator<java.util.Map.Entry<String, com.fasterxml.jackson.databind.JsonNode>> fields = node.fields();
            while (fields.hasNext()) {
                java.util.Map.Entry<String, com.fasterxml.jackson.databind.JsonNode> entry = fields.next();
                removeRefFields(entry.getValue());
            }
        } else if (node.isArray()) {
            // 閫掑綊澶勭悊鏁扮粍涓殑姣忎釜鍏冪礌
            for (com.fasterxml.jackson.databind.JsonNode arrayElement : node) {
                removeRefFields(arrayElement);
            }
        }
    }
    
    /**
     * 瑙ｆ瀽JSON鏍煎紡鐨勫伐鍏疯皟鐢拒绝执行：     * @param jsonText AI杩斿洖鐨勬枃鏈紝鍖呭惈JSON鏍煎紡鐨勫伐鍏疯皟鐢拒绝执行：     * @return 宸ュ叿璋冪敤请锋眰鍒楄〃
     */
    private List<dev.langchain4j.agent.tool.ToolExecutionRequest> parseJsonToolCalls(String jsonText) {
        List<dev.langchain4j.agent.tool.ToolExecutionRequest> toolRequests = new ArrayList<>();
        
        try {
            com.fasterxml.jackson.databind.ObjectMapper mapper = new com.fasterxml.jackson.databind.ObjectMapper();
            
            // 灏濊瘯鐩存帴瑙ｆ瀽涓哄崟涓伐鍏疯皟鐢?            if (jsonText.trim().startsWith("{")) {
                try {
                    com.fasterxml.jackson.databind.JsonNode jsonNode = mapper.readTree(jsonText);
                    if (jsonNode.has("name") && jsonNode.has("arguments")) {
                        String toolName = jsonNode.get("name").asText();
                        String argumentsJson = jsonNode.get("arguments").toString();
                        
                        toolRequests.add(dev.langchain4j.agent.tool.ToolExecutionRequest.builder()
                                .name(toolName)
                                .arguments(argumentsJson)
                                .build());
                        
                        System.out.println("瑙ｆ瀽鍒癑SON宸ュ叿璋冪敤: " + toolName + " 鍙傛暟: " + argumentsJson);
                    }
                } catch (Exception e) {
                    // 如果傛灉瑙ｆ瀽鍗曚釜澶辫触锛屽皾请曡В鏋愭暟缁拒绝执行：                }
            }
            
            // 灏濊瘯瑙ｆ瀽涓篛penAI鐨則ool_calls鏍煎紡
            if (toolRequests.isEmpty() && jsonText.contains("\"tool_calls\"")) {
                com.fasterxml.jackson.databind.JsonNode jsonNode = mapper.readTree(jsonText);
                if (jsonNode.has("tool_calls")) {
                    com.fasterxml.jackson.databind.JsonNode toolCalls = jsonNode.get("tool_calls");
                    if (toolCalls.isArray()) {
                        for (com.fasterxml.jackson.databind.JsonNode toolCall : toolCalls) {
                            if (toolCall.has("function")) {
                                com.fasterxml.jackson.databind.JsonNode function = toolCall.get("function");
                                if (function.has("name")) {
                                    String toolName = function.get("name").asText();
                                    String argumentsJson = function.has("arguments") ? 
                                            function.get("arguments").toString() : "{}";
                                    
                                    toolRequests.add(dev.langchain4j.agent.tool.ToolExecutionRequest.builder()
                                            .name(toolName)
                                            .arguments(argumentsJson)
                                            .build());
                                    
                                    System.out.println("瑙ｆ瀽鍒癘penAI鏍煎紡宸ュ叿璋冪敤: " + toolName + " 鍙傛暟: " + argumentsJson);
                                }
                            }
                        }
                    }
                }
            }
        } catch (Exception e) {
            System.err.println("瑙ｆ瀽JSON宸ュ叿璋冪敤澶辫触: " + e.getMessage());
            e.printStackTrace();
        }
        
        return toolRequests;
    }

    /**
     * 瑙ｆ瀽XML鏍煎紡鐨勫伐鍏疯皟鐢拒绝执行：     * @param aiText AI杩斿洖鐨勬枃鏈紝鍖呭惈XML鏍煎紡鐨勫伐鍏疯皟鐢拒绝执行：     * @return 宸ュ叿璋冪敤请锋眰鍒楄〃
     */
    private List<dev.langchain4j.agent.tool.ToolExecutionRequest> parseXmlToolCalls(String aiText) {
        List<dev.langchain4j.agent.tool.ToolExecutionRequest> toolRequests = new ArrayList<>();
        
        try {
            // 浣跨敤姝ｅ垯琛ㄨ揪寮忔彁鍙?function_calls>鏍囩鍐呭
            java.util.regex.Pattern pattern = java.util.regex.Pattern.compile("<function_calls>(.*?)</function_calls>", java.util.regex.Pattern.DOTALL);
            java.util.regex.Matcher matcher = pattern.matcher(aiText);
            
            if (matcher.find()) {
                String functionCallsContent = matcher.group(1);
                
                // 鎻愬彇鎵€鏈夌殑<invoke>鏍囩
                java.util.regex.Pattern invokePattern = java.util.regex.Pattern.compile("<invoke name=\"([^\"]+)\">(.*?)</invoke>", java.util.regex.Pattern.DOTALL);
                java.util.regex.Matcher invokeMatcher = invokePattern.matcher(functionCallsContent);
                
                while (invokeMatcher.find()) {
                    String toolName = invokeMatcher.group(1);
                    String parametersContent = invokeMatcher.group(2);
                    
                    // 鎻愬彇鎵€鏈夊弬鏁拒绝执行：                    Map<String, Object> arguments = new HashMap<>();
                    java.util.regex.Pattern paramPattern = java.util.regex.Pattern.compile("<parameter name=\"([^\"]+)\">([^<]*)</parameter>");
                    java.util.regex.Matcher paramMatcher = paramPattern.matcher(parametersContent);
                    
                    while (paramMatcher.find()) {
                        String paramName = paramMatcher.group(1);
                        String paramValue = paramMatcher.group(2);
                        arguments.put(paramName, paramValue);
                    }
                    
                    // 杞崲涓篔SON瀛楃涓?                    com.fasterxml.jackson.databind.ObjectMapper mapper = new com.fasterxml.jackson.databind.ObjectMapper();
                    String argumentsJson = mapper.writeValueAsString(arguments);
                    
                    // 鍒涘缓ToolExecutionRequest
                    dev.langchain4j.agent.tool.ToolExecutionRequest toolRequest = 
                        dev.langchain4j.agent.tool.ToolExecutionRequest.builder()
                            .name(toolName)
                            .arguments(argumentsJson)
                            .build();
                    
                    toolRequests.add(toolRequest);
                    System.out.println("瑙ｆ瀽鍒癤ML宸ュ叿璋冪敤: " + toolName + " 鍙傛暟: " + argumentsJson);
                }
            }
        } catch (Exception e) {
            System.err.println("瑙ｆ瀽XML宸ュ叿璋冪敤澶辫触: " + e.getMessage());
            e.printStackTrace();
        }
        
        return toolRequests;
    }
}