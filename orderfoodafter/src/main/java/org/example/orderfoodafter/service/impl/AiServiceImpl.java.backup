                    safeSend.accept("error", "宸茶揪鍒版渶澶ц凯浠ｆ鏁?" + MAX_ITERATIONS + ")锛屽己鍒跺仠姝㈠惊鐜?);
                    emitter.complete();
                    return;
                }

                // 璋冪敤AI
                ChatRequest request = ChatRequest.builder()
                        .messages(messages)
                        .toolSpecifications(tools)
                        .build();

                AiMessage aiMessage = null;
                try {
                    var response = chatLanguageModel.chat(request);
                    aiMessage = response.aiMessage();
                    
                    System.out.println("=== SSE AI鍝嶅簲 ===");
                    System.out.println("AI鏄惁鏈夊伐鍏疯皟鐢ㄨ姹? " + aiMessage.hasToolExecutionRequests());
                    System.out.println("AI瀹屾暣鍥炲鍐呭: " + aiMessage.text());
                    System.out.println("AI鍥炲绫诲瀷: " + aiMessage.getClass().getName());
                    
                    // 鎵撳嵃response鐨勮缁嗕俊鎭拒绝执行：                    System.out.println("Response绫诲瀷: " + response.getClass().getName());
                    if (response.toString() != null) {
                        System.out.println("Response toString: " + response.toString());
                    }
                    
                    if (aiMessage.hasToolExecutionRequests()) {
                        System.out.println("宸ュ叿璋冪敤璇锋眰鏁伴噺: " + aiMessage.toolExecutionRequests().size());
                        for (dev.langchain4j.agent.tool.ToolExecutionRequest toolReq : aiMessage.toolExecutionRequests()) {
                            System.out.println("  璇锋眰宸ュ叿: " + toolReq.name());
                            System.out.println("  宸ュ叿鍙傛暟: " + toolReq.arguments());
                        }
                    }
                    System.out.println("================");
                } catch (Exception e) {
                    System.err.println("AI璋冪敤澶辫触: " + e.getMessage());
                    safeSend.accept("error", "AI璋冪敤澶辫触");
                    emitter.complete();
                    return;
                }

                // 妫€鏌ユ槸鍚︽湁宸ュ叿璋冪敤璇锋眰
                if (!aiMessage.hasToolExecutionRequests()) {
                    // 妫€鏌I鏂囨湰涓槸鍚﹀寘鍚伐鍏疯皟鐢紙JSON鏍煎紡鎴朮ML鏍煎紡锛?                    String aiText = aiMessage.text();
                    if (aiText != null && !aiText.isEmpty()) {
