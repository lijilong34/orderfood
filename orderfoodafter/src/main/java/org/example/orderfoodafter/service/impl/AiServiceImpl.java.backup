                                            // 鎺ㄩ€佸伐鍏锋墽琛岀粨鏋拒绝执行：                                            safeSend.accept("tool_result", "宸ュ叿鎵ц缁撴灉: " + toolResult);
                                            
                                            // 灏嗗伐鍏锋墽琛岀粨鏋滄坊鍔犲埌娑堟伅涓?                                            enhancedMessages.add(dev.langchain4j.data.message.ToolExecutionResultMessage.from(
