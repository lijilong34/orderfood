<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="org.example.orderfoodafter.mapper.InventoryMapper">
  <resultMap id="BaseResultMap" type="org.example.orderfoodafter.entity.Inventory">
    <!--@mbg.generated-->
    <!--@Table inventory-->
    <id column="id" jdbcType="BIGINT" property="id" />
    <result column="shop_id" jdbcType="BIGINT" property="shopId" />
    <result column="material_name" jdbcType="VARCHAR" property="materialName" />
    <result column="spec" jdbcType="VARCHAR" property="spec" />
    <result column="unit" jdbcType="VARCHAR" property="unit" />
    <result column="stock_quantity" jdbcType="DECIMAL" property="stockQuantity" />
    <result column="warning_threshold" jdbcType="DECIMAL" property="warningThreshold" />
    <result column="supplier_id" jdbcType="BIGINT" property="supplierId" />
    <result column="create_time" jdbcType="TIMESTAMP" property="createTime" />
    <result column="update_time" jdbcType="TIMESTAMP" property="updateTime" />
  </resultMap>

  <!-- 包含供应商名称的扩展 ResultMap -->
  <resultMap id="InventoryWithSupplierMap" type="org.example.orderfoodafter.entity.Inventory" extends="BaseResultMap">
    <result column="supplier_name" jdbcType="VARCHAR" property="supplierName" />
  </resultMap>

  <sql id="Base_Column_List">
    <!--@mbg.generated-->
    id, shop_id, material_name, spec, unit, stock_quantity, warning_threshold, supplier_id, 
    last_purchase_time, create_time, update_time
  </sql>

  <!-- 连表查询库存及供应商名称 -->
  <select id="selectInventoryWithSupplier" resultMap="InventoryWithSupplierMap">
    SELECT 
      i.id,
      i.shop_id,
      i.material_name,
      i.spec,
      i.unit,
      i.stock_quantity,
      i.warning_threshold,
      i.supplier_id,
      i.create_time,
      i.update_time,
      s.name as supplier_name
    FROM inventory i
    LEFT JOIN supplier s ON i.supplier_id = s.id
    <where>
      <if test="params.shopId != null">
        AND i.shop_id = #{params.shopId}
      </if>
      <if test="params.keyword != null and params.keyword != ''">
        AND i.material_name LIKE CONCAT('%', #{params.keyword}, '%')
      </if>
      <if test="params.status != null and params.status != ''">
        <choose>
          <when test="params.status == 'out'">
            AND i.stock_quantity = 0
          </when>
          <when test="params.status == 'low'">
            AND i.stock_quantity > 0 AND i.stock_quantity &lt;= 5
          </when>
          <when test="params.status == 'sufficient'">
            AND i.stock_quantity > 5
          </when>
        </choose>
      </if>
    </where>
    ORDER BY i.update_time DESC
  </select>
</mapper>