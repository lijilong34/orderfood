<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="org.example.orderfoodafter.mapper.EmployeeMapper">
  <resultMap id="BaseResultMap" type="org.example.orderfoodafter.entity.Employee">
    <!--@mbg.generated-->
    <!--@Table employee-->
    <id column="id" jdbcType="BIGINT" property="id" />
    <result column="shop_id" jdbcType="BIGINT" property="shopId" />
    <result column="username" jdbcType="VARCHAR" property="username" />
    <result column="shopName" property="shopName"/>
    <result column="password" jdbcType="VARCHAR" property="password" />
    <result column="post" jdbcType="VARCHAR" property="post" />
    <result column="work_status" jdbcType="TINYINT" property="workStatus" />
    <result column="schedule" jdbcType="VARCHAR" property="schedule" />
    <result column="attendance_count" jdbcType="INTEGER" property="attendanceCount" />
    <result column="create_time" jdbcType="TIMESTAMP" property="createTime" />
    <result column="update_time" jdbcType="TIMESTAMP" property="updateTime" />
  </resultMap>
  <sql id="Base_Column_List">
    <!--@mbg.generated-->
    id, shop_id, username, `password`, post, work_status, schedule, attendance_count, 
    create_time, update_time
  </sql>

  <select id="selectemployee" resultMap="BaseResultMap">
    SELECT employee.id,employee.username,employee.password,employee.shop_id,shop.`name` as shopName,employee.post,employee.`schedule`,employee.work_status from employee left join shop on employee.shop_id=shop.id
    <trim prefix="WHERE" prefixOverrides="AND |OR ">
      <if test="ew != null and ew.customSqlSegment != ''">
        ${ew.customSqlSegment.replace('WHERE','')}
      </if>
    </trim>
    </select>
</mapper>