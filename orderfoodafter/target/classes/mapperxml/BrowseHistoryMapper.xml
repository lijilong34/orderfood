  <resultMap id="selecthistorybyuserIdmap" type="org.example.orderfoodafter.entity.BrowseHistory">
    <!--@mbg.generated-->
    <!--@Table browse_history-->
    <id column="id" jdbcType="BIGINT" property="id" />
    <result column="product_id" jdbcType="BIGINT" property="productId" />
    <result column="create_time" jdbcType="TIMESTAMP" property="createTime" />
     <result column="shopname" property="shopname"/>
    <association property="product" javaType="org.example.orderfoodafter.entity.Product">
      <result column="name" property="name"/>
      <result column="image" property="image"/>
      <result column="price" property="price"/>
      <result column="stock" property="stock"/>
      <result column="status" property="status"/>
    </association>
  </resultMap>

    <select id="selecthistorybyuserId" resultMap="selecthistorybyuserIdmap">
      SELECT browse_history.id,browse_history.product_id,shop.`name` as shopname,product.`name`,product.image,product.price,stock,product.`status`,browse_history.create_time FROM product INNER JOIN browse_history ON browse_history.product_id=product.id INNER JOIN shop ON product.shop_id=shop.id
